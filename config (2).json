{
  "data": {
    "ticker": "^GSPC",
    "start_date": "1986-01-01",
    "end_date": "2024-12-31",
    "interval": "1d",
    "seq_len": 60,
    "train_ratio": 0.8,
    "val_ratio": 0.1
  },
  "model": {
    "input_size": 44,
    "hidden_size": 64,
    "num_layers": 2,
    "dropout": 0.3,
    "bidirectional": false,
    "output_size": 1
  },
  "train": {
    "epochs": 200,
    "batch_size": 32,
    "learning_rate": 0.001,
    "weight_decay": 0.001,
    "patience": 30,
    "gradient_clip": 0.5,
    "seed": 42,
    "device": "auto"
  },
  "checkpoint_dir": "/content/checkpoints",
  "results_dir": "/content/results"
}